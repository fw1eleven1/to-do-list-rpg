# 이 파일은 커밋됩니다. 실제 값은 절대 넣지 마세요.
# 복사해서 사용: cp .env.example .env.local

# 로컬 개발: docker-compose 의 postgres
# 프로덕션: 클라우드 DB 연결 문자열 (+ ?sslmode=require)
DATABASE_URL=postgresql://rpg:rpg@localhost:5432/rpg

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3001

# https://console.cloud.google.com/apis/credentials
# 승인된 리디렉션 URI: http://localhost:3001/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
