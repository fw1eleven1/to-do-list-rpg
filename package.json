{
  "name": "to-do-list-rpg",
  "version": "0.1.0",
  "private": true,
  "//engines": "Next 16 은 20.9+ 를 요구하지만, 우리는 process.loadEnvFile(20.12+) 을 쓴다.",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:security": "node --import tsx --env-file=.env.local --conditions=react-server scripts/security-check.mts",
    "test:fallback": "node --import tsx --env-file=.env.local scripts/fallback-check.mts",
    "quest:preview": "node --import tsx --env-file=.env.local --conditions=react-server scripts/quest-preview.mts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@date-fns/tz": "^1.5.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.47.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
