# /var/www/to-do-list-rpg/.env  (프로덕션 환경변수)
#
#   cp deploy/env.production.example /var/www/to-do-list-rpg/.env
#   chmod 600 /var/www/to-do-list-rpg/.env
#   nano /var/www/to-do-list-rpg/.env
#
# .gitignore 가 .env* 를 무시하므로 git pull 로 덮이지 않는다.
#
# 주의: 이 파일은 두 곳에서 읽힌다 — 규칙이 겹치는 범위 안에서만 써야 한다.
#   - deploy.sh / PM2 기동 셸: `set -a; source .env; set +a` 로 읽는다 (셸 문법)
#   - next start: Next 가 자체 파서로 읽는다
# 그래서 값은 따옴표 없이, 공백 없이, 아래 문자를 피해서 쓴다.
#   - `#` 은 주석 시작으로 잘린다. 비밀번호에 넣지 말 것.
#   - `$` 는 셸에서 변수로 치환된다.
#   - 공백이 있으면 source 가 깨진다.
# 비밀번호는 openssl rand -hex 24 처럼 영숫자만 나오는 방법을 쓰는 게 안전하다.

# ── DB ───────────────────────────────────────────────
# 같은 서버의 postgres 라면 localhost. SSL 불필요.
DATABASE_URL=postgresql://rpg:비밀번호@localhost:5432/rpg
# 다른 서버/관리형 DB 라면 반드시 sslmode 를 켠다:
# DATABASE_URL=postgresql://rpg:비밀번호@db.example.com:5432/rpg?sslmode=require

# ── 인증 ─────────────────────────────────────────────
# 반드시 새로 만든다. 개발용과 같은 값을 쓰면 개발 PC 가 털렸을 때 프로덕션 세션이 위조된다.
#   openssl rand -base64 32
AUTH_SECRET=

# 공개 주소. 뒤에 슬래시 없이. Cloudflare 뒤라 https 다.
AUTH_URL=https://rpg.pjsk.kr

# 리버스 프록시 뒤에서 도는 self-host 배포라 필요하다.
# 이게 없으면 NextAuth 가 X-Forwarded-Proto 를 믿지 않아 콜백 주소를 틀리게 만든다.
AUTH_TRUST_HOST=true

# 비워두면 Google 버튼이 숨고 이메일+비밀번호만 동작한다.
# 채운다면 Google 콘솔의 승인된 리디렉션 URI 에
#   https://rpg.pjsk.kr/api/auth/callback/google
# 를 반드시 추가할 것. 개발용(localhost:3001)과 별개다.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── AI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
