# /etc/to-do-list-rpg.env  (systemd EnvironmentFile)
#
#   sudo cp deploy/env.production.example /etc/to-do-list-rpg.env
#   sudo chown root:root /etc/to-do-list-rpg.env
#   sudo chmod 600 /etc/to-do-list-rpg.env
#   sudo nano /etc/to-do-list-rpg.env
#
# 주의: systemd EnvironmentFile 은 셸이 아니다.
#   - 따옴표를 쓰면 값의 일부로 들어갈 수 있다. 그냥 KEY=값 으로 쓴다.
#   - $VAR 치환, 명령 치환($(...)) 이 되지 않는다.
#   - 값에 # 이 있으면 주석으로 잘리므로 비밀번호에 # 을 넣지 말 것.

# ── DB ───────────────────────────────────────────────
# 같은 서버의 postgres 라면 localhost. SSL 불필요.
DATABASE_URL=postgresql://rpg:비밀번호@localhost:5432/rpg
# 다른 서버/관리형 DB 라면 반드시 sslmode 를 켠다:
# DATABASE_URL=postgresql://rpg:비밀번호@db.example.com:5432/rpg?sslmode=require

# ── 인증 ─────────────────────────────────────────────
# 반드시 새로 만든다. 개발용과 같은 값을 쓰면 개발 PC 가 털렸을 때 프로덕션 세션이 위조된다.
#   openssl rand -base64 32
AUTH_SECRET=

# 공개 주소. https 로, 뒤에 슬래시 없이.
AUTH_URL=https://rpg.example.com

# 리버스 프록시 뒤에서 도는 self-host 배포라 필요하다.
# 이게 없으면 NextAuth 가 X-Forwarded-Proto 를 믿지 않아 콜백 주소를 http 로 만든다.
AUTH_TRUST_HOST=true

# 비워두면 Google 버튼이 숨고 이메일+비밀번호만 동작한다.
# 채운다면 Google 콘솔의 승인된 리디렉션 URI 에
#   https://rpg.example.com/api/auth/callback/google
# 를 반드시 추가할 것. 개발용(localhost:3001)과 별개다.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── AI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
